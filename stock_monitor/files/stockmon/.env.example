# Copy to .env and fill in. Load with: set -a; source .env; set +a
# (or use systemd Environment= lines / a process manager).

# ntfy: only needed if you use a protected/self-hosted topic
# NTFY_TOKEN=

# Discord webhook URL (Server Settings -> Integrations -> Webhooks -> New Webhook)
DISCORD_WEBHOOK_URL=

# Email (Gmail App Password recommended, not your login password)
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-specific-password

# Web feed -> dhosae.in/stock. Must MATCH the STOCK_INGEST_TOKEN set on the
# website host. Generate one with:  openssl rand -hex 32
STOCK_INGEST_TOKEN=
