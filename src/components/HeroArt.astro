---
/**
 * HeroArt — "first light".
 * One horizon, one sun just clearing it. The whole theme in a single line:
 * a day beginning, and the quiet knowledge that it will end.
 * Pure vector, no assets. Sits full-width between Today and the days.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<div class:list={["horizon", className]} aria-hidden="true">
  <svg viewBox="0 0 1200 150" preserveAspectRatio="xMidYMid meet" role="img">
    <title>first light</title>
    <defs>
      <linearGradient id="hz-line" x1="0" y1="0" x2="1200" y2="0" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="#1b1814" stop-opacity="0" />
        <stop offset="0.5" stop-color="#1b1814" stop-opacity="0.32" />
        <stop offset="1" stop-color="#1b1814" stop-opacity="0" />
      </linearGradient>
    </defs>

    <!-- the rays, rising from behind the sun -->
    <g class="hz-rays" stroke="#6322e8" stroke-width="2" stroke-linecap="round" stroke-opacity="0.55">
      <line x1="600" y1="118" x2="600" y2="60" />
      <line x1="600" y1="118" x2="558" y2="72" />
      <line x1="600" y1="118" x2="642" y2="72" />
      <line x1="600" y1="118" x2="524" y2="92" />
      <line x1="600" y1="118" x2="676" y2="92" />
    </g>

    <!-- the horizon -->
    <line x1="0" y1="118" x2="1200" y2="118" stroke="url(#hz-line)" stroke-width="1.5" />

    <!-- the sun, just clearing it -->
    <path class="hz-sun" d="M 562 118 A 38 38 0 0 1 638 118 Z" fill="#6322e8" />
  </svg>
</div>

<style>
  .horizon {
    width: 100%;
    margin-top: var(--space-md);
  }
  .horizon svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hz-sun {
      transform-box: fill-box;
      transform-origin: 50% 100%;
      transform: scaleY(0);
      animation: hz-rise 1400ms var(--ease) 200ms forwards;
    }
    .hz-rays line {
      stroke-dasharray: 70;
      stroke-dashoffset: 70;
      animation: hz-ray 900ms var(--ease) forwards;
    }
    .hz-rays line:nth-child(1) { animation-delay: 1100ms; }
    .hz-rays line:nth-child(2) { animation-delay: 1300ms; }
    .hz-rays line:nth-child(3) { animation-delay: 1300ms; }
    .hz-rays line:nth-child(4) { animation-delay: 1500ms; }
    .hz-rays line:nth-child(5) { animation-delay: 1500ms; }
  }

  @keyframes hz-rise { to { transform: scaleY(1); } }
  @keyframes hz-ray { to { stroke-dashoffset: 0; } }
</style>
