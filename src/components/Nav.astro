---
import Wordmark from "./Wordmark.astro";
---

<header class="nav">
  <div class="container nav__inner">
    <Wordmark size="md" href="/" />
    <nav class="nav__links">
      <a href="/dojo" class="nav__link mono">dojo</a>
      <a href="/studio" class="nav__studio mono" rel="nofollow">
        <span class="nav__dot" aria-hidden="true"></span>studio
      </a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 80%, transparent);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    height: 68px;
  }
  .nav__links {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
  }
  .nav__link {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: lowercase;
    color: var(--ink-3);
    transition: color 200ms var(--ease);
  }
  .nav__link:hover { color: var(--violet-ink); }
  .nav__studio {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: lowercase;
    color: var(--ink-3);
    transition: color 200ms var(--ease);
  }
  .nav__studio:hover { color: var(--violet-ink); }
  .nav__dot {
    width: 0.42em;
    height: 0.42em;
    border-radius: 100px;
    background: var(--violet);
  }
</style>
