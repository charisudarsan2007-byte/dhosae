---
import type { Post } from "../../lib/db";
import { toLocalInput, formatStamp } from "../../lib/format";

interface Props {
  post?: Partial<Post>;
  action: string;
  submitLabel: string;
  showDelete?: boolean;
  originalSlug?: string;
  /** New entries are stamped automatically (IST). Editing reveals the field. */
  lockTime?: boolean;
}
const { post = {}, action, submitLabel, showDelete = false, originalSlug, lockTime = false } = Astro.props;
// datetime-local wants "YYYY-MM-DDTHH:MM" in IST wall-clock.
const whenValue = post.publishedAt ? toLocalInput(post.publishedAt) : toLocalInput(new Date().toISOString());
// What the automatic stamp will read as, for the "filled in for you" hint.
const autoStamp = formatStamp(new Date());
---

<form method="POST" action={action} class="pform">
  {originalSlug !== undefined && <input type="hidden" name="originalSlug" value={originalSlug} />}

  <label class="field">
    <span class="field__label">Title <span class="field__hint">— what today was</span></span>
    <input class="input" type="text" name="title" value={post.title ?? ""} required maxlength="160"
      placeholder="A title for today" autofocus />
  </label>

  <label class="field">
    <span class="field__label">A line beneath it <span class="field__hint">— optional; shown under the title</span></span>
    <textarea class="textarea" name="dek" rows="2" maxlength="400"
      placeholder="One quiet line, if you want one.">{post.dek ?? ""}</textarea>
  </label>

  {lockTime ? (
    <div class="row" style="margin-top:1.4rem; grid-template-columns: 1fr;">
      <p class="autostamp mono">
        <span class="autostamp__dot" aria-hidden="true"></span>
        Stamped automatically — <strong>{autoStamp}</strong> <span class="field__hint">(India Standard Time)</span>
      </p>
      <label class="field" style="margin-top:1.1rem;">
        <span class="field__label">Link <span class="field__hint">— blank = from the title</span></span>
        <input class="input mono" type="text" name="slug" value={post.slug ?? ""}
          pattern="[a-z0-9-]*" placeholder="auto" />
      </label>
    </div>
  ) : (
    <div class="row row--2" style="margin-top:1.4rem;">
      <label class="field" style="margin-top:0;">
        <span class="field__label">Date &amp; time <span class="field__hint">— change it if you like</span></span>
        <input class="input mono" type="datetime-local" name="publishedAt" value={whenValue} required />
      </label>
      <label class="field" style="margin-top:0;">
        <span class="field__label">Link <span class="field__hint">— blank = from the title</span></span>
        <input class="input mono" type="text" name="slug" value={post.slug ?? ""}
          pattern="[a-z0-9-]*" placeholder="auto" />
      </label>
    </div>
  )}

  <label class="field">
    <span class="field__label">The day <span class="field__hint">— Markdown: ## heading, **bold**, *italic*, &gt; quote, - list</span></span>
    <textarea class="textarea textarea--body" name="body"
      placeholder="Write the day here. As long or as short as it was…">{post.body ?? ""}</textarea>
  </label>

  <div class="actions">
    <label class="check"><input type="checkbox" name="draft" checked={post.draft ?? false} /> Keep as a draft — not shown on the site yet</label>
  </div>

  <div class="actions">
    <button type="submit" class="btn btn--violet">{submitLabel}</button>
    <a href="/studio" class="btn btn--ghost">Cancel</a>
    <span class="spacer"></span>
    {showDelete && (
      <button type="submit" name="_action" value="delete" class="btn btn--ghost s-del"
        formnovalidate onclick="return confirm('Delete this day for good?')">Delete</button>
    )}
  </div>
</form>

<style>
  .s-del { color: var(--red-ink); border-color: #f0cdd0; }
  .s-del:hover { border-color: var(--red); background: var(--red-wash); }
  .autostamp {
    display: flex; align-items: center; gap: 0.55rem; flex-wrap: wrap;
    font-size: 0.82rem; color: var(--ink-2);
    background: var(--violet-wash); border: 1px solid #d9c9fb;
    border-radius: var(--radius); padding: 0.7rem 0.85rem;
  }
  .autostamp strong { color: var(--violet-ink); font-weight: 600; }
  .autostamp__dot {
    width: 0.5rem; height: 0.5rem; border-radius: 100px;
    background: var(--violet); flex: none;
  }
</style>
