---
import Base from "../layouts/Base.astro";
import HeroArt from "../components/HeroArt.astro";
import { getPosts, getContentMany } from "../lib/db";
import { formatDay, formatTime } from "../lib/format";

const days = await getPosts(); // published only, newest first
const now = new Date();
const todayDay = formatDay(now);
const todayTime = formatTime(now);

// the standing note — written by you in /studio/creed
const c = await getContentMany(["creed_eyebrow", "creed_title", "creed_body1", "creed_body2"]);
const showNote = c.creed_title.trim() !== "";
---

<Base>
  <!-- ============ TODAY ============ -->
  <section class="today container">
    <p class="today__creed">live each day as if it were your last</p>
    <h1 class="today__h">
      <span class="today__lead">Today is</span>
      <span class="today__day" id="clock-day">{todayDay}</span>
    </h1>
    <p class="today__time mono">
      <span id="clock-time">{todayTime}</span><span class="today__still"> — and it is still yours.</span>
    </p>
    <p class="today__intro">
      A journal kept one day at a time. Each entry below is a single day,
      written as if it might be the last one.
    </p>
  </section>

  <HeroArt />

  <!-- ============ THE DAYS ============ -->
  <section class="days container" id="days" aria-labelledby="days-h">
    <h2 id="days-h" class="sr-only">The days</h2>
    {days.length === 0 ? (
      <p class="days__empty">The first day is being written.</p>
    ) : (
      <ol class="days__list">
        {days.map((p) => {
          const d = new Date(p.publishedAt);
          return (
            <li class="day" data-reveal>
              <a href={`/posts/${p.slug}`} class="day__link">
                <time class="day__when mono" datetime={d.toISOString()}>
                  <span class="day__date">{formatDay(d)}</span>
                  <span class="day__time">{formatTime(d)}</span>
                </time>
                <span class="day__main">
                  <span class="day__title">{p.title}</span>
                  {p.dek && <span class="day__dek">{p.dek}</span>}
                  <span class="day__go mono">read the day <span class="arrow">→</span></span>
                </span>
              </a>
            </li>
          );
        })}
      </ol>
    )}
  </section>

  <!-- ============ THE STANDING NOTE (warm, first person — written in /studio) ============ -->
  {showNote && (
    <section class="note" aria-labelledby="note-h">
      <div class="container note__inner">
        {c.creed_eyebrow.trim() !== "" && (
          <p class="note__eyebrow mono">{c.creed_eyebrow}</p>
        )}
        <h2 class="note__title" id="note-h" data-reveal set:text={c.creed_title} />
        {(c.creed_body1.trim() !== "" || c.creed_body2.trim() !== "") && (
          <div class="note__cols">
            {c.creed_body1.trim() !== "" && <p data-reveal set:text={c.creed_body1} />}
            {c.creed_body2.trim() !== "" && <p data-reveal set:text={c.creed_body2} />}
          </div>
        )}
      </div>
    </section>
  )}
</Base>

<script>
  // The clock keeps today honest — it ticks while you read.
  const fmtDay = new Intl.DateTimeFormat("en-GB", {
    timeZone: "Asia/Kolkata", weekday: "long", day: "numeric", month: "long", year: "numeric",
  });
  const fmtClock = new Intl.DateTimeFormat("en-GB", {
    timeZone: "Asia/Kolkata", hour12: false, hour: "2-digit", minute: "2-digit",
  });
  function phrase(): { day: string; time: string } {
    const now = new Date();
    const parts = fmtClock.formatToParts(now);
    const hour = Number(parts.find((p) => p.type === "hour")?.value ?? "0") % 24;
    const minute = parts.find((p) => p.type === "minute")?.value ?? "00";
    const h12 = hour % 12 === 0 ? 12 : hour % 12;
    const phaseOf =
      hour < 5 ? "at night" : hour < 12 ? "in the morning" : hour < 17 ? "in the afternoon" : hour < 21 ? "in the evening" : "at night";
    return { day: fmtDay.format(now), time: `${h12}.${minute} ${phaseOf}` };
  }
  const dayEl = document.getElementById("clock-day");
  const timeEl = document.getElementById("clock-time");
  function tick() {
    const { day, time } = phrase();
    if (dayEl) dayEl.textContent = day;
    if (timeEl) timeEl.textContent = time;
  }
  tick();
  setInterval(tick, 15000);
</script>

<style>
  /* ---------- TODAY ---------- */
  .today { padding-top: clamp(3rem, 1.5rem + 7vw, 7rem); padding-bottom: var(--space-lg); }
  .today__creed {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.16em;
    text-transform: lowercase;
    color: var(--violet-ink);
    margin-bottom: var(--space-md);
  }
  .today__h {
    font-family: var(--font-display);
    font-weight: 380;
    letter-spacing: -0.02em;
    line-height: 1.02;
    max-width: 18ch;
  }
  .today__lead {
    display: block;
    font-size: var(--step-2);
    color: var(--ink-3);
    font-style: italic;
    font-weight: 360;
  }
  .today__day {
    display: block;
    font-size: var(--step-5);
    color: var(--ink);
    font-weight: 460;
    letter-spacing: -0.03em;
    margin-top: 0.15em;
  }
  .today__time {
    margin-top: var(--space-md);
    font-size: var(--step-0);
    color: var(--ink-2);
    letter-spacing: 0.01em;
  }
  .today__still { color: var(--ink-4); }
  .today__intro {
    margin-top: var(--space-lg);
    font-family: var(--font-serif);
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 46ch;
  }

  /* ---------- THE DAYS ---------- */
  .days { margin-top: var(--space-xl); }
  .days__empty {
    font-family: var(--font-serif); font-size: var(--step-2);
    color: var(--ink-3); padding-block: var(--space-xl);
  }
  .days__list { list-style: none; margin: 0; padding: 0; }
  .day { border-top: 1px solid var(--line); }
  .day:last-child { border-bottom: 1px solid var(--line); }
  .day__link {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xs);
    padding: clamp(1.6rem, 1rem + 2vw, 2.8rem) 0;
    transition: padding-left 360ms var(--ease);
  }
  .day__link:hover { padding-left: 0.6rem; }
  .day__when {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem 0.9rem;
    align-items: baseline;
    font-size: var(--step--1);
    color: var(--ink-3);
  }
  .day__date { color: var(--violet-ink); letter-spacing: 0.01em; }
  .day__time { color: var(--ink-4); }
  .day__main { display: block; }
  .day__title {
    display: block;
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 480;
    letter-spacing: -0.025em;
    line-height: 1.08;
    color: var(--ink);
    transition: color 220ms var(--ease);
    max-width: 26ch;
  }
  .day__link:hover .day__title { color: var(--violet-ink); }
  .day__dek {
    display: block;
    margin-top: 0.5rem;
    font-family: var(--font-serif);
    font-size: var(--step-1);
    font-weight: 360;
    color: var(--ink-2);
    max-width: 52ch;
    line-height: 1.4;
  }
  .day__go {
    display: inline-block;
    margin-top: 0.9rem;
    font-size: var(--step--1);
    color: var(--ink-4);
    letter-spacing: 0.04em;
  }
  .day__go .arrow { display: inline-block; transition: transform 240ms var(--ease); }
  .day__link:hover .day__go { color: var(--violet-ink); }
  .day__link:hover .day__go .arrow { transform: translateX(5px); }

  @media (min-width: 760px) {
    .day__link {
      grid-template-columns: 15rem 1fr;
      gap: var(--space-lg);
      align-items: start;
    }
    .day__when { flex-direction: column; gap: 0.35rem; padding-top: 0.5rem; }
  }

  /* ---------- THE STANDING NOTE ---------- */
  .note {
    margin-top: var(--space-2xl);
    background: var(--paper-2);
    border-top: 1px solid var(--line);
    padding-block: var(--space-2xl);
  }
  .note__eyebrow { color: var(--violet-ink); letter-spacing: 0.16em; margin-bottom: var(--space-md); }
  .note__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-3);
    letter-spacing: -0.025em;
    line-height: 1.1;
    max-width: 24ch;
    color: var(--ink);
  }
  .note__cols {
    margin-top: var(--space-lg);
    display: grid; gap: var(--space-lg); grid-template-columns: 1fr; max-width: 68ch;
  }
  .note__cols p {
    font-family: var(--font-serif);
    color: var(--ink-2);
    font-size: var(--step-1);
    line-height: 1.6;
  }
  @media (min-width: 720px) {
    .note__cols { grid-template-columns: 1fr 1fr; gap: var(--space-xl); }
  }
</style>
