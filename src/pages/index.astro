---
import Base from "../layouts/Base.astro";
import { getPosts, getContentMany } from "../lib/db";
import { formatDay, formatTime } from "../lib/format";
import { skyView } from "../lib/sky";

const allDays = await getPosts(); // published only, newest first
const HOME_LIMIT = 3; // only the most recent days greet you; the rest are discovered
const days = allDays.slice(0, HOME_LIMIT);
const moreCount = allDays.length - days.length;
const now = new Date();
const todayDay = formatDay(now);
const todayTime = formatTime(now);
const sky = skyView(now); // one honest line about the real sky over India now

// the standing note — written by you in /studio/creed
const c = await getContentMany(["creed_eyebrow", "creed_title", "creed_body1", "creed_body2"]);
const showNote = c.creed_title.trim() !== "";
---

<Base>
  <!-- ============ TODAY ============ -->
  <section class="today container">
    <!-- the light rests behind these words, slowly turning; run a cursor or a
         finger across them and they ripple around it like water, then settle -->
    <div class="today__stage refract">
      <p class="today__creed">live each day as if it were your last</p>
      <h1 class="today__h">
        <span class="today__lead">Today is</span>
        <span class="today__day" id="clock-day">{todayDay}</span>
      </h1>
      <p class="today__time mono">
        <span id="clock-time">{todayTime}</span><span class="today__still"> — and it is still yours.</span>
      </p>
    </div>
    <p class="today__intro">
      A journal kept one day at a time. Each entry below is a single day,
      written as if it might be the last one.
    </p>
    <p class="today__sky mono" id="sky-cap">{sky.caption}</p>
  </section>

  <!-- ============ THE DAYS ============ -->
  <section class="days container" id="days" aria-labelledby="days-h">
    <h2 id="days-h" class="sr-only">The days</h2>
    {days.length === 0 ? (
      <p class="days__empty">The first day is being written.</p>
    ) : (
      <ol class="days__list">
        {days.map((p) => {
          const d = new Date(p.publishedAt);
          return (
            <li class="day" data-reveal>
              <a href={`/posts/${p.slug}`} class="day__link">
                <time class="day__when mono" datetime={d.toISOString()}>
                  <span class="day__date">{formatDay(d)}</span>
                  <span class="day__time">{formatTime(d)}</span>
                </time>
                <span class="day__main">
                  <span class="day__title">{p.title}</span>
                  {p.dek && <span class="day__dek">{p.dek}</span>}
                  <span class="day__go mono">read the day <span class="arrow">→</span></span>
                </span>
              </a>
            </li>
          );
        })}
      </ol>
    )}
    {moreCount > 0 && (
      <a href="/days" class="days__more">
        <span class="days__more-main">
          <span class="days__more-lead mono">there are more days</span>
          <span class="days__more-text">{moreCount} earlier {moreCount === 1 ? "day is" : "days are"} kept back here — wander in when you like.</span>
        </span>
        <span class="days__more-go mono">all the days <span class="arrow">→</span></span>
      </a>
    )}
  </section>

  <!-- ============ THE DOJO (the work beside the journal — a dark doorway) ============ -->
  <section class="dojo container" aria-labelledby="dojo-h">
    <a href="/dojo" class="dojo__card" data-reveal>
      <div class="dojo__body">
        <p class="dojo__eyebrow mono"><span class="dojo__dot" aria-hidden="true"></span>beside the journal — a place to build</p>
        <h2 class="dojo__title" id="dojo-h">The Dojo</h2>
        <p class="dojo__lead">
          The journal is where I reckon with the day. The Dojo is where I put in
          the hard hours — interactive labs that turn raw knowledge into something
          I can actually use.
        </p>
        <p class="dojo__meta mono">Two disciplines so far — finance &amp; supply chain, drilled until they stick</p>
      </div>
      <span class="dojo__go mono">step into the dojo <span class="arrow">→</span></span>
    </a>
  </section>

  <!-- ============ STOCK (the watchtower beside the dojo — a second dark doorway) ============ -->
  <section class="stock container" aria-labelledby="stock-h">
    <a href="/stock" class="stock__card" data-reveal>
      <div class="stock__body">
        <p class="stock__eyebrow mono"><span class="stock__dot" aria-hidden="true"></span>beside the dojo — the watchtower</p>
        <h2 class="stock__title" id="stock-h">Stock</h2>
        <p class="stock__lead">
          A small always-on monitor stands watch over BSE filings. The moment a
          company on my watchlist drops a board-meeting announcement, a push lands
          on my phone. It reads and it alerts — it never trades.
        </p>
        <p class="stock__meta mono">Alert-only · BSE corporate filings · live console</p>
      </div>
      <span class="stock__go mono">enter the watchtower <span class="arrow">→</span></span>
    </a>
  </section>

  <!-- ============ THE STANDING NOTE (warm, first person — written in /studio) ============ -->
  {showNote && (
    <section class="note" aria-labelledby="note-h">
      <div class="container note__inner">
        {c.creed_eyebrow.trim() !== "" && (
          <p class="note__eyebrow mono">{c.creed_eyebrow}</p>
        )}
        <h2 class="note__title" id="note-h" data-reveal set:text={c.creed_title} />
        {(c.creed_body1.trim() !== "" || c.creed_body2.trim() !== "") && (
          <div class="note__cols">
            {c.creed_body1.trim() !== "" && <p data-reveal set:text={c.creed_body1} />}
            {c.creed_body2.trim() !== "" && <p data-reveal set:text={c.creed_body2} />}
          </div>
        )}
      </div>
    </section>
  )}
</Base>

<script>
  // The clock keeps today honest — it ticks while you read.
  const fmtDay = new Intl.DateTimeFormat("en-GB", {
    timeZone: "Asia/Kolkata", weekday: "long", day: "numeric", month: "long", year: "numeric",
  });
  const fmtClock = new Intl.DateTimeFormat("en-GB", {
    timeZone: "Asia/Kolkata", hour12: false, hour: "2-digit", minute: "2-digit",
  });
  function phrase(): { day: string; time: string } {
    const now = new Date();
    const parts = fmtClock.formatToParts(now);
    const hour = Number(parts.find((p) => p.type === "hour")?.value ?? "0") % 24;
    const minute = parts.find((p) => p.type === "minute")?.value ?? "00";
    const h12 = hour % 12 === 0 ? 12 : hour % 12;
    const phaseOf =
      hour < 5 ? "at night" : hour < 12 ? "in the morning" : hour < 17 ? "in the afternoon" : hour < 21 ? "in the evening" : "at night";
    return { day: fmtDay.format(now), time: `${h12}.${minute} ${phaseOf}` };
  }
  const dayEl = document.getElementById("clock-day");
  const timeEl = document.getElementById("clock-time");
  function tick() {
    const { day, time } = phrase();
    if (dayEl) dayEl.textContent = day;
    if (timeEl) timeEl.textContent = time;
  }
  tick();
  setInterval(tick, 15000);
</script>

<style>
  /* ---------- TODAY ---------- */
  .today {
    padding-top: clamp(4rem, 2rem + 9vw, 9rem);
    padding-bottom: var(--space-lg);
    min-height: min(82vh, 720px); /* room for the light to drift behind the words */
  }
  /* the stage carries the water-lens filter (added by JS when the orb is near);
     a little padding keeps bent letters from clipping at the edges */
  .today__stage {
    padding: 0.4em 0.1em;
    margin: -0.4em -0.1em;
    will-change: filter;
  }
  .today__sky {
    margin-top: var(--space-lg);
    font-size: var(--step--1);
    letter-spacing: 0.05em;
    color: var(--ink-4);
    font-variant: small-caps;
  }
  .today__creed {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.16em;
    text-transform: lowercase;
    color: var(--violet-ink);
    margin-bottom: var(--space-md);
  }
  .today__h {
    font-family: var(--font-display);
    font-weight: 380;
    letter-spacing: -0.02em;
    line-height: 1.02;
    max-width: 18ch;
  }
  .today__lead {
    display: block;
    font-size: var(--step-2);
    color: var(--ink-3);
    font-style: italic;
    font-weight: 360;
  }
  .today__day {
    display: block;
    font-size: var(--step-5);
    color: var(--ink);
    font-weight: 460;
    letter-spacing: -0.03em;
    margin-top: 0.15em;
  }
  .today__time {
    margin-top: var(--space-md);
    font-size: var(--step-0);
    color: var(--ink-2);
    letter-spacing: 0.01em;
  }
  .today__still { color: var(--ink-4); }
  .today__intro {
    margin-top: var(--space-lg);
    font-family: var(--font-serif);
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 46ch;
  }

  /* ---------- THE DAYS ---------- */
  .days { margin-top: var(--space-xl); }
  .days__empty {
    font-family: var(--font-serif); font-size: var(--step-2);
    color: var(--ink-3); padding-block: var(--space-xl);
  }
  .days__list { list-style: none; margin: 0; padding: 0; }
  .day { border-top: 1px solid var(--line); }
  .day:last-child { border-bottom: 1px solid var(--line); }
  .day__link {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xs);
    padding: clamp(1.6rem, 1rem + 2vw, 2.8rem) 0;
    transition: padding-left 360ms var(--ease);
  }
  .day__link:hover { padding-left: 0.6rem; }
  .day__when {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem 0.9rem;
    align-items: baseline;
    font-size: var(--step--1);
    color: var(--ink-3);
  }
  .day__date { color: var(--violet-ink); letter-spacing: 0.01em; }
  .day__time { color: var(--ink-4); }
  .day__main { display: block; }
  .day__title {
    display: block;
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 480;
    letter-spacing: -0.025em;
    line-height: 1.08;
    color: var(--ink);
    transition: color 220ms var(--ease);
    max-width: 26ch;
  }
  .day__link:hover .day__title { color: var(--violet-ink); }
  .day__dek {
    display: block;
    margin-top: 0.5rem;
    font-family: var(--font-serif);
    font-size: var(--step-1);
    font-weight: 360;
    color: var(--ink-2);
    max-width: 52ch;
    line-height: 1.4;
  }
  .day__go {
    display: inline-block;
    margin-top: 0.9rem;
    font-size: var(--step--1);
    color: var(--ink-4);
    letter-spacing: 0.04em;
  }
  .day__go .arrow { display: inline-block; transition: transform 240ms var(--ease); }
  .day__link:hover .day__go { color: var(--violet-ink); }
  .day__link:hover .day__go .arrow { transform: translateX(5px); }

  @media (min-width: 760px) {
    .day__link {
      grid-template-columns: 15rem 1fr;
      gap: var(--space-lg);
      align-items: start;
    }
    .day__when { flex-direction: column; gap: 0.35rem; padding-top: 0.5rem; }
  }

  /* ---------- MORE DAYS (the rest, discovered) ---------- */
  .days__more {
    display: flex; align-items: center; justify-content: space-between;
    gap: var(--space-md); flex-wrap: wrap;
    margin-top: var(--space-lg);
    padding: clamp(1.3rem, 1rem + 1.5vw, 1.9rem) clamp(1.1rem, 0.8rem + 1.5vw, 1.7rem);
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    transition: transform 240ms var(--ease), border-color 240ms var(--ease);
  }
  .days__more:hover { transform: translateY(-2px); border-color: var(--line-strong); }
  .days__more-lead {
    display: block; font-size: var(--step--1); letter-spacing: 0.06em;
    color: var(--violet-ink); margin-bottom: 0.3rem;
  }
  .days__more-text {
    font-family: var(--font-serif); font-size: var(--step-0);
    color: var(--ink-2); max-width: 44ch;
  }
  .days__more-go {
    font-size: var(--step--1); color: var(--ink-3); letter-spacing: 0.04em; white-space: nowrap;
  }
  .days__more:hover .days__more-go { color: var(--violet-ink); }
  .days__more-go .arrow { display: inline-block; transition: transform 240ms var(--ease); }
  .days__more:hover .days__more-go .arrow { transform: translateX(5px); }

  /* ---------- THE DOJO (a dark doorway in the warm page) ---------- */
  .dojo { margin-top: var(--space-xl); }
  .dojo__card {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-lg);
    flex-wrap: wrap;
    padding: clamp(1.8rem, 1.2rem + 2.4vw, 3rem) clamp(1.4rem, 1rem + 2vw, 2.6rem);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(120% 140% at 100% 0%, #2a2118 0%, #1a1610 55%),
      #17130d;
    border: 1px solid #322a1e;
    box-shadow: var(--shadow-md);
    position: relative;
    overflow: hidden;
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  /* a faint terminal-grid wash, echoing the Dojo's own backdrop */
  .dojo__card::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(#ffffff05 1px, transparent 1px),
      linear-gradient(90deg, #ffffff05 1px, transparent 1px);
    background-size: 34px 34px;
    pointer-events: none;
  }
  .dojo__card:hover {
    transform: translateY(-3px);
    border-color: #54c79f55;
    box-shadow: var(--shadow-lg);
  }
  .dojo__body { position: relative; max-width: 52ch; }
  .dojo__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6em;
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: lowercase;
    color: #b9a3ff;
    margin-bottom: var(--space-sm);
  }
  .dojo__dot {
    width: 0.5em;
    height: 0.5em;
    border-radius: 100px;
    background: #36d39a;
    box-shadow: 0 0 10px #36d39a;
    animation: dojo-pulse 2.4s var(--ease) infinite;
  }
  @keyframes dojo-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
  .dojo__title {
    font-family: var(--font-display);
    font-weight: 460;
    font-size: var(--step-4);
    letter-spacing: -0.03em;
    line-height: 1.02;
    color: #f4f0e7;
    margin: 0;
  }
  .dojo__lead {
    margin-top: var(--space-md);
    font-family: var(--font-serif);
    font-size: var(--step-1);
    line-height: 1.5;
    color: #d8cfbe;
  }
  .dojo__meta {
    margin-top: var(--space-md);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    color: #9a8f7b;
  }
  .dojo__go {
    position: relative;
    white-space: nowrap;
    font-size: var(--step-0);
    letter-spacing: 0.04em;
    color: #f4f0e7;
    padding-bottom: 0.2em;
    border-bottom: 1px solid #54c79f66;
  }
  .dojo__go .arrow { display: inline-block; transition: transform 240ms var(--ease); }
  .dojo__card:hover .dojo__go { color: #6ee0b4; }
  .dojo__card:hover .dojo__go .arrow { transform: translateX(6px); }
  @media (prefers-reduced-motion: reduce) {
    .dojo__dot { animation: none; }
  }

  /* ---------- STOCK (a second dark doorway — cool/cyan, the watchtower) ---------- */
  .stock { margin-top: var(--space-lg); }
  .stock__card {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-lg);
    flex-wrap: wrap;
    padding: clamp(1.8rem, 1.2rem + 2.4vw, 3rem) clamp(1.4rem, 1rem + 2vw, 2.6rem);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(120% 140% at 100% 0%, #11212a 0%, #0d161d 55%),
      #0a1117;
    border: 1px solid #1c2b33;
    box-shadow: var(--shadow-md);
    position: relative;
    overflow: hidden;
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .stock__card::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(#ffffff05 1px, transparent 1px),
      linear-gradient(90deg, #ffffff05 1px, transparent 1px);
    background-size: 34px 34px;
    pointer-events: none;
  }
  .stock__card:hover {
    transform: translateY(-3px);
    border-color: #3dd6f555;
    box-shadow: var(--shadow-lg);
  }
  .stock__body { position: relative; max-width: 52ch; }
  .stock__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6em;
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: lowercase;
    color: #7fd9ef;
    margin-bottom: var(--space-sm);
  }
  .stock__dot {
    width: 0.5em;
    height: 0.5em;
    border-radius: 100px;
    background: #11e29b;
    box-shadow: 0 0 10px #11e29b;
    animation: dojo-pulse 2.4s var(--ease) infinite;
  }
  .stock__title {
    font-family: var(--font-display);
    font-weight: 460;
    font-size: var(--step-4);
    letter-spacing: -0.03em;
    line-height: 1.02;
    color: #eaf4fb;
    margin: 0;
  }
  .stock__lead {
    margin-top: var(--space-md);
    font-family: var(--font-serif);
    font-size: var(--step-1);
    line-height: 1.5;
    color: #c4d2dd;
  }
  .stock__meta {
    margin-top: var(--space-md);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    color: #6f8492;
  }
  .stock__go {
    position: relative;
    white-space: nowrap;
    font-size: var(--step-0);
    letter-spacing: 0.04em;
    color: #eaf4fb;
    padding-bottom: 0.2em;
    border-bottom: 1px solid #3dd6f566;
  }
  .stock__go .arrow { display: inline-block; transition: transform 240ms var(--ease); }
  .stock__card:hover .stock__go { color: #6fe3ff; }
  .stock__card:hover .stock__go .arrow { transform: translateX(6px); }
  @media (prefers-reduced-motion: reduce) {
    .stock__dot { animation: none; }
  }

  /* ---------- THE STANDING NOTE ---------- */
  .note {
    margin-top: var(--space-2xl);
    background: var(--paper-2);
    border-top: 1px solid var(--line);
    padding-block: var(--space-2xl);
  }
  .note__eyebrow { color: var(--violet-ink); letter-spacing: 0.16em; margin-bottom: var(--space-md); }
  .note__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-3);
    letter-spacing: -0.025em;
    line-height: 1.1;
    max-width: 24ch;
    color: var(--ink);
  }
  .note__cols {
    margin-top: var(--space-lg);
    display: grid; gap: var(--space-lg); grid-template-columns: 1fr; max-width: 68ch;
  }
  .note__cols p {
    font-family: var(--font-serif);
    color: var(--ink-2);
    font-size: var(--step-1);
    line-height: 1.6;
  }
  @media (min-width: 720px) {
    .note__cols { grid-template-columns: 1fr 1fr; gap: var(--space-xl); }
  }
</style>
