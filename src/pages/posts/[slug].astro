---
import Base from "../../layouts/Base.astro";
import { getPost } from "../../lib/db";
import { formatDay, formatTime } from "../../lib/format";
import { marked } from "marked";

const slug = Astro.params.slug!;
const post = await getPost(slug);
if (!post || post.draft) {
  return new Response("Not found", { status: 404 });
}

marked.setOptions({ gfm: true, breaks: false });
const html = await marked.parse(post.body);
const published = new Date(post.publishedAt);
---

<Base title={`${post.title} · dhosae`} description={post.dek || "A day, written as if it were the last."}>
  <article class="day container">
    <a href="/#days" class="day__back mono">← all the days</a>

    <header class="day__head">
      <p class="day__stamp mono">
        <span class="day__date">{formatDay(published)}</span>
        <span class="day__sep" aria-hidden="true">·</span>
        <time class="day__time" datetime={published.toISOString()}>{formatTime(published)}</time>
      </p>
      <h1 class="day__title">{post.title}</h1>
      {post.dek && <p class="day__dek">{post.dek}</p>}
      {post.readingMinutes && <p class="day__read mono">{post.readingMinutes} min</p>}
    </header>

    <div class="prose" set:html={html} />

    <footer class="day__foot">
      <span class="day__rule" aria-hidden="true"></span>
      <a href="/#days" class="link">Read another day →</a>
    </footer>
  </article>
</Base>

<style>
  .day { max-width: 48rem; padding-top: var(--space-lg); padding-bottom: var(--space-2xl); }
  .day__back { color: var(--ink-3); font-size: var(--step--1); display: inline-block; }
  .day__back:hover { color: var(--violet-ink); }

  .day__head { margin-top: var(--space-lg); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--line); }
  .day__stamp {
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem;
    font-size: var(--step-0); letter-spacing: 0.01em;
  }
  .day__date { color: var(--violet-ink); }
  .day__sep { color: var(--ink-4); }
  .day__time { color: var(--ink-3); }
  .day__title {
    margin-top: var(--space-md);
    font-family: var(--font-display);
    font-weight: 460;
    font-size: var(--step-4); line-height: 1.04; letter-spacing: -0.03em; max-width: 22ch;
  }
  .day__dek {
    margin-top: var(--space-sm);
    font-family: var(--font-serif); font-weight: 360; font-size: var(--step-2);
    line-height: 1.35; color: var(--ink-2); max-width: 42ch; font-style: italic;
  }
  .day__read { margin-top: var(--space-md); color: var(--ink-4); font-size: var(--step--1); }

  /* prose — set in the reading serif, like a letter */
  .prose {
    margin-top: var(--space-xl);
    max-width: var(--measure);
    font-family: var(--font-serif);
    font-size: var(--step-1);
    font-weight: 360;
    line-height: 1.72;
    color: var(--ink);
  }
  .prose :global(p) { margin-top: 1.4em; }
  .prose :global(p:first-child) { margin-top: 0; }
  .prose :global(h2) { font-family: var(--font-display); margin-top: 2em; font-size: var(--step-2); letter-spacing: -0.02em; }
  .prose :global(h3) { font-family: var(--font-display); margin-top: 1.7em; font-size: var(--step-1); }
  .prose :global(strong) { font-weight: 620; }
  .prose :global(em) { font-style: italic; }
  .prose :global(a) {
    color: var(--violet-ink);
    text-decoration: underline; text-decoration-thickness: 1.5px; text-underline-offset: 2px;
  }
  .prose :global(ul), .prose :global(ol) { margin-top: 1.3em; padding-left: 1.3em; }
  .prose :global(li) { margin-top: 0.5em; }
  .prose :global(li::marker) { color: var(--violet); }
  .prose :global(blockquote) {
    margin-top: 1.5em; padding-left: 1.1em; border-left: 3px solid var(--violet);
    color: var(--ink-2); font-style: italic;
  }
  .prose :global(code) {
    font-family: var(--font-mono); font-size: 0.86em;
    background: var(--paper-3); padding: 0.12em 0.36em; border-radius: 4px;
  }
  .prose :global(hr) { margin: 2.2em 0; border: 0; border-top: 1px solid var(--line); }

  .day__foot { margin-top: var(--space-2xl); }
  .day__rule { display: block; height: 2px; background: var(--violet); width: 3rem; margin-bottom: var(--space-md); }
</style>
