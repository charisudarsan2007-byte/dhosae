---
import Studio from "../../layouts/Studio.astro";
import { getContentMany, setContent } from "../../lib/db";

const KEYS = ["creed_eyebrow", "creed_title", "creed_body1", "creed_body2"];
let saved = false;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  await setContent({
    creed_eyebrow: String(form.get("creed_eyebrow") ?? "").trim(),
    creed_title: String(form.get("creed_title") ?? "").trim(),
    creed_body1: String(form.get("creed_body1") ?? "").trim(),
    creed_body2: String(form.get("creed_body2") ?? "").trim(),
  });
  saved = true;
}

const c = await getContentMany(KEYS);
---

<Studio title="the standing note · studio">
  <header style="margin-bottom:1.6rem;">
    <p class="eyebrow" style="color:var(--violet-ink)">the standing note</p>
    <h1 class="s-h" style="font-size:var(--step-4);">Why this place exists</h1>
    <p class="s-sub">A short note that sits beneath your days on the homepage. Write it in your own voice. Leave the heading empty to hide it altogether.</p>
  </header>

  <div class="s-card">
    <form method="POST">
      <label class="field" style="margin-top:0;">
        <span class="field__label">Small line above <span class="field__hint">— optional</span></span>
        <input class="input mono" type="text" name="creed_eyebrow" value={c.creed_eyebrow}
          placeholder="why I keep this" maxlength="80" />
      </label>

      <label class="field">
        <span class="field__label">Heading</span>
        <textarea class="textarea" name="creed_title" rows="2" maxlength="240"
          placeholder="The one sentence that says what this place is.">{c.creed_title}</textarea>
      </label>

      <div class="row row--2" style="margin-top:1.4rem;">
        <label class="field" style="margin-top:0;">
          <span class="field__label">First paragraph</span>
          <textarea class="textarea" name="creed_body1" rows="6" placeholder="Your words…">{c.creed_body1}</textarea>
        </label>
        <label class="field" style="margin-top:0;">
          <span class="field__label">Second paragraph <span class="field__hint">— optional</span></span>
          <textarea class="textarea" name="creed_body2" rows="6" placeholder="Your words…">{c.creed_body2}</textarea>
        </label>
      </div>

      {saved && <p class="s-ok">Saved. Your homepage is updated.</p>}

      <div class="actions">
        <button type="submit" class="btn btn--violet">Save the note</button>
        <a href="/" target="_blank" rel="noreferrer" class="btn btn--ghost">View homepage ↗</a>
      </div>
    </form>
  </div>
</Studio>
