---
import Studio from "../../layouts/Studio.astro";
import PostForm from "../../components/studio/PostForm.astro";
import { getPost, upsertPost, slugify, type Post } from "../../lib/db";
import { fromLocalInput } from "../../lib/format";

let error = "";
let draft: Partial<Post> = {};

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const title = String(form.get("title") ?? "").trim();
  let slug = String(form.get("slug") ?? "").trim();
  if (!slug) slug = slugify(title);
  const dek = String(form.get("dek") ?? "").trim();
  const body = String(form.get("body") ?? "");
  const publishedAt = fromLocalInput(String(form.get("publishedAt") ?? "").trim());
  const draftFlag = form.get("draft") != null;

  draft = { title, slug, dek, body, publishedAt, readingMinutes: null, featured: false, draft: draftFlag };

  if (!title) error = "A title is needed.";
  else if (!slug) error = "Could not build a link from that title — type one.";
  else if (await getPost(slug)) error = `The link "${slug}" is already in use. Pick another.`;
  else {
    await upsertPost({ slug, title, dek, body, publishedAt, readingMinutes: null, featured: false, draft: draftFlag });
    return Astro.redirect("/studio");
  }
}
---

<Studio title="a new day · studio">
  <header style="margin-bottom:1.4rem;">
    <p class="eyebrow" style="color:var(--violet-ink)">a new day</p>
    <h1 class="s-h" style="font-size:var(--step-4);">Write today.</h1>
  </header>
  <div class="s-card">
    {error && <p class="s-note">{error}</p>}
    <PostForm post={draft} action="/studio/new" submitLabel="Publish" />
  </div>
</Studio>
