---
import Studio from "../../layouts/Studio.astro";
import { getPosts, getContent, getNote, setNote, getNotes } from "../../lib/db";
import { formatDate, formatClock, formatDay, istDayKey } from "../../lib/format";

const today = istDayKey();

// The post-it saves here (post to /studio, redirect back — no resubmit on refresh).
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  if (form.get("_action") === "note") {
    await setNote(today, String(form.get("note") ?? ""));
    return Astro.redirect("/studio#postit");
  }
}

const posts = await getPosts({ includeDrafts: true });
const noteTitle = await getContent("creed_title");
const todayNote = await getNote(today);
const noteCount = (await getNotes()).length;
const todayLabel = formatDay(new Date());
---

<Studio title="studio · dhosae">
  <header class="head">
    <div>
      <p class="eyebrow" style="color:var(--violet-ink)">your studio</p>
      <h1 class="s-h">The days</h1>
      <p class="s-sub">Every entry is one day. Write it, change it, or take it back. Nothing is shown to anyone until you say so.</p>
    </div>
    <a href="/studio/new" class="btn btn--violet">＋ Write today</a>
  </header>

  <section class="postit" id="postit" aria-labelledby="postit-h">
    <form method="POST" action="/studio" class="postit__pad">
      <input type="hidden" name="_action" value="note" />
      <div class="postit__top">
        <span class="postit__tag mono">today's note</span>
        <span class="postit__date mono">{todayLabel}</span>
      </div>
      <label class="sr-only" id="postit-h" for="postit-body">A short note for today</label>
      <textarea id="postit-body" class="postit__body" name="note" rows="4"
        placeholder="Anything for today — something exciting, something to remember, a thing not to forget…">{todayNote?.body ?? ""}</textarea>
      <div class="postit__foot">
        <span class="postit__hint mono">kept for today · a fresh one waits tomorrow</span>
        <div class="postit__btns">
          {noteCount > 0 && <a href="/studio/notes" class="postit__past mono">past notes →</a>}
          <button type="submit" class="btn btn--violet postit__save">Pin it</button>
        </div>
      </div>
    </form>
  </section>

  {noteTitle.trim() === "" && (
    <a href="/studio/creed" class="nudge">
      <strong>Write the standing note.</strong>
      <span>The short note on your homepage is empty — say, in your own words, why this place exists. →</span>
    </a>
  )}

  <ol class="plist">
    {posts.length === 0 && <li class="empty">No days yet. Write your first one →</li>}
    {posts.map((p) => (
      <li class="prow">
        <a href={`/studio/${p.slug}`} class="prow__link">
          <span class="prow__main">
            <span class="prow__title">{p.title}</span>
            <span class="prow__meta mono">
              {p.draft && <em class="badge badge--draft">draft</em>}
              <time>{formatDate(new Date(p.publishedAt))} · {formatClock(new Date(p.publishedAt))}</time>
              {p.readingMinutes && <span>· {p.readingMinutes} min</span>}
            </span>
          </span>
          <span class="prow__edit mono">edit →</span>
        </a>
      </li>
    ))}
  </ol>
</Studio>

<style>
  /* ---- the post-it ---- */
  .postit { margin-bottom: 1.8rem; }
  .postit__pad {
    position: relative;
    background: linear-gradient(180deg, #fff6c9 0%, #fdedae 100%);
    border: 1px solid #efdc8a;
    border-radius: 4px 4px 10px 10px;
    padding: 1.1rem 1.2rem 1rem;
    box-shadow: 0 10px 22px -14px rgba(80, 60, 0, 0.5);
    transform: rotate(-0.5deg);
  }
  .postit__top {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 0.75rem; margin-bottom: 0.6rem;
  }
  .postit__tag {
    font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: #8a6d18;
  }
  .postit__date { font-size: 0.72rem; color: #a9883a; }
  .postit__body {
    width: 100%; resize: vertical; min-height: 5.5rem;
    font-family: var(--font-serif); font-size: 1.02rem; line-height: 1.55;
    color: #4a3c12; background: transparent; border: 0; padding: 0;
  }
  .postit__body::placeholder { color: #b69a4d; }
  .postit__body:focus { outline: none; }
  .postit__foot {
    display: flex; align-items: center; justify-content: space-between;
    gap: 0.75rem; flex-wrap: wrap; margin-top: 0.7rem;
    border-top: 1px dashed #e2cd7c; padding-top: 0.7rem;
  }
  .postit__hint { font-size: 0.68rem; color: #a9883a; letter-spacing: 0.02em; }
  .postit__btns { display: flex; align-items: center; gap: 0.9rem; }
  .postit__past { font-size: 0.72rem; color: #8a6d18; transition: color 160ms var(--ease); }
  .postit__past:hover { color: #5e4a0f; text-decoration: underline; }
  .postit__save { padding-block: 0.4rem; }

  .head {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 1.5rem; flex-wrap: wrap; margin-bottom: 2rem;
  }
  .head .s-h { font-size: var(--step-4); margin-top: 0.3rem; }

  .nudge {
    display: block; background: var(--violet-wash); border: 1px solid #d9c9fb;
    border-radius: var(--radius-lg); padding: 1rem 1.2rem; margin-bottom: 1.6rem;
    transition: transform 200ms var(--ease);
  }
  .nudge:hover { transform: translateY(-2px); }
  .nudge strong { display: block; color: var(--violet-ink); }
  .nudge span { color: var(--ink-2); font-size: var(--step--1); }

  .plist { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--line); }
  .empty { padding: 2rem 0; color: var(--ink-3); }
  .prow { border-bottom: 1px solid var(--line); }
  .prow__link {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1.1rem 0.5rem; border-radius: var(--radius);
    transition: background 160ms var(--ease), padding-left 200ms var(--ease);
  }
  .prow__link:hover { background: var(--paper); padding-left: 0.9rem; }
  .prow__title {
    font-family: var(--font-display); font-size: var(--step-2); letter-spacing: -0.02em;
    color: var(--ink); display: block;
  }
  .prow__link:hover .prow__title { color: var(--violet-ink); }
  .prow__meta { display: flex; align-items: center; gap: 0.5rem; color: var(--ink-3); font-size: 0.78rem; margin-top: 0.3rem; }
  .badge {
    font-style: normal; font-size: 0.66rem; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 0.1rem 0.4rem; border-radius: 100px;
  }
  .badge--violet { color: var(--violet-ink); background: var(--violet-wash); }
  .badge--draft { color: var(--ink-3); background: var(--paper-3); }
  .prow__edit { color: var(--ink-4); font-size: 0.78rem; white-space: nowrap; }
  .prow__link:hover .prow__edit { color: var(--violet-ink); }
</style>
