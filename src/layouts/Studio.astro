---
import "../styles/global.css";
import Wordmark from "../components/Wordmark.astro";

interface Props {
  title?: string;
  /** show the top bar with logout (false on login/setup screens) */
  chrome?: boolean;
}
const { title = "studio · dhosae", chrome = true } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
  </head>
  <body class="studio">
    {chrome && (
      <header class="sbar">
        <div class="sbar__inner">
          <a href="/studio" class="sbar__brand">
            <Wordmark size="sm" href="/studio" />
            <span class="sbar__tag mono">studio</span>
          </a>
          <nav class="sbar__nav mono">
            <a href="/studio" class="sbar__link">the days</a>
            <a href="/studio/creed" class="sbar__link">the note</a>
            <a href="/" class="sbar__link" target="_blank" rel="noreferrer">view site ↗</a>
            <form method="POST" action="/studio/logout" class="sbar__logout">
              <button type="submit" class="sbar__link sbar__out">lock</button>
            </form>
          </nav>
        </div>
      </header>
    )}
    <main class="swrap">
      <slot />
    </main>

    <style is:global>
      body.studio { background: var(--paper-2); min-height: 100vh; }

      .sbar {
        position: sticky; top: 0; z-index: 50;
        background: color-mix(in srgb, var(--paper) 86%, transparent);
        backdrop-filter: saturate(140%) blur(12px);
        -webkit-backdrop-filter: saturate(140%) blur(12px);
        border-bottom: 1px solid var(--line);
      }
      .sbar__inner {
        max-width: 60rem; margin-inline: auto;
        padding: 0 clamp(1rem, 0.5rem + 2vw, 2rem);
        height: 60px; display: flex; align-items: center; justify-content: space-between; gap: 1rem;
      }
      .sbar__brand { display: inline-flex; align-items: center; gap: 0.6rem; }
      .sbar__tag {
        font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase;
        color: var(--violet-ink); border: 1px solid var(--violet-wash);
        background: var(--violet-wash); padding: 0.15rem 0.45rem; border-radius: 100px;
      }
      .sbar__nav { display: flex; align-items: center; gap: clamp(0.6rem, 0.3rem + 1.5vw, 1.6rem); }
      .sbar__link {
        font-size: 0.78rem; letter-spacing: 0.04em; color: var(--ink-3);
        background: none; border: 0; padding: 0; transition: color 180ms var(--ease);
      }
      .sbar__link:hover { color: var(--violet-ink); }
      .sbar__out { color: var(--ink-3); }
      .sbar__logout { display: inline; }
      @media (max-width: 560px) {
        .sbar__nav { gap: 0.7rem; }
        .sbar__link { font-size: 0.72rem; }
      }

      .swrap {
        max-width: 60rem; margin-inline: auto;
        padding: clamp(1.5rem, 1rem + 3vw, 3.5rem) clamp(1rem, 0.5rem + 2vw, 2rem) 6rem;
      }

      /* ---- studio form atoms (shared) ---- */
      .s-card {
        background: var(--paper); border: 1px solid var(--line);
        border-radius: var(--radius-lg); padding: clamp(1.25rem, 1rem + 2vw, 2.25rem);
        box-shadow: var(--shadow-sm);
      }
      .s-h {
        font-family: var(--font-display); font-size: var(--step-3);
        letter-spacing: -0.025em; line-height: 1.05;
      }
      .s-sub { color: var(--ink-3); margin-top: 0.5rem; max-width: 52ch; }
      .field { display: block; margin-top: 1.4rem; }
      .field__label {
        display: block; font-family: var(--font-mono); font-size: 0.74rem;
        letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-3);
        margin-bottom: 0.5rem;
      }
      .field__hint { font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--ink-4); }
      .input, .textarea, .select {
        width: 100%; font: inherit; color: var(--ink);
        background: var(--paper); border: 1px solid var(--line-strong);
        border-radius: var(--radius); padding: 0.7rem 0.85rem;
        transition: border-color 180ms var(--ease), box-shadow 180ms var(--ease);
      }
      .input:focus, .textarea:focus, .select:focus {
        outline: none; border-color: var(--violet);
        box-shadow: 0 0 0 3px var(--violet-wash);
      }
      .textarea { resize: vertical; line-height: 1.6; }
      .textarea--body { min-height: 22rem; font-family: var(--font-mono); font-size: 0.92rem; }
      .row { display: grid; gap: 1rem; }
      @media (min-width: 620px) { .row--3 { grid-template-columns: 1fr 1fr 1fr; } .row--2 { grid-template-columns: 1fr 1fr; } }
      .check { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--ink-2); }
      .check input { width: 1.05rem; height: 1.05rem; accent-color: var(--violet); }
      .actions { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; margin-top: 1.8rem; }
      .spacer { flex: 1; }
      .s-note {
        font-family: var(--font-mono); font-size: 0.78rem; color: var(--red-ink);
        background: var(--red-wash); border: 1px solid #f3c9cc; border-radius: var(--radius);
        padding: 0.6rem 0.8rem; margin-top: 1rem;
      }
      .s-ok {
        font-family: var(--font-mono); font-size: 0.78rem; color: var(--green-ink);
        background: var(--green-wash); border: 1px solid #bfe6cf; border-radius: var(--radius);
        padding: 0.6rem 0.8rem; margin-top: 1rem;
      }
    </style>
  </body>
</html>
